{
  "enabled": true,
  "name": "Auto Push & Bing IndexNow Ping",
  "description": "After every agent task, stages all changes, commits with a timestamp, pushes to GitHub, then pings Bing IndexNow to request fast indexing.",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "powershell -ExecutionPolicy Bypass -File \"c:\\Users\\bgsmi\\OneDrive\\Documents\\us-thebrainsong-en.com\\autopush.ps1\"",
    "timeout": 60
  }
}